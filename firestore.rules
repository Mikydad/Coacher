rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ──────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Uses exists() (cheaper than get()) to check circle membership
    function isCircleMember(circleId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/circles/$(circleId)/members/$(request.auth.uid));
    }

    // Denormalized join index under the user doc (kept in sync on join/leave).
    function hasCircleIndex(circleId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)/circleIds/$(circleId));
    }

    // Chat/activity read: member doc OR circleIds index (covers account-switch races).
    function canAccessCircleContent(circleId) {
      return isCircleMember(circleId) || hasCircleIndex(circleId);
    }

    // Reads circle doc once to check moderatorIds list
    function isCircleModerator(circleId) {
      return isSignedIn() &&
        get(/databases/$(database)/documents/circles/$(circleId)).data.moderatorIds.hasAny([request.auth.uid]);
    }

    // Join/leave only touch memberCount on the circle doc (see UserCircleMembershipService).
    function circleMemberCountOnlyChange() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberCount']);
    }

    // Member doc is written in the same transaction; avoid exists() (ordering).
    function isJoinIncrementingMemberCount() {
      return isSignedIn()
        && circleMemberCountOnlyChange()
        && request.resource.data.memberCount == resource.data.memberCount + 1;
    }

    function isLeaveDecrementingMemberCount() {
      return isSignedIn()
        && circleMemberCountOnlyChange()
        && request.resource.data.memberCount == resource.data.memberCount - 1;
    }

    // ─── Users ─────────────────────────────────────────────────────────────
    // Users can read/write their own document and ALL subcollections
    // (routines, blocks, tasks, reminders, goals, analytics, circleIds, etc.)

    match /users/{uid} {
      allow read, write: if isUser(uid);

      match /{document=**} {
        allow read, write: if isUser(uid);
      }
    }

    // ─── Circles ───────────────────────────────────────────────────────────

    match /circles/{circleId} {

      // Any signed-in user can read circles (needed for search/browse)
      allow read: if isSignedIn();

      // Any signed-in user can create — creatorId must match their uid
      allow create: if isSignedIn()
        && request.resource.data.creatorId == request.auth.uid;

      // Moderators can update metadata; members can bump memberCount on join/leave.
      allow update: if isCircleModerator(circleId)
        || isJoinIncrementingMemberCount()
        || isLeaveDecrementingMemberCount();

      // Only the creator can delete
      allow delete: if isCircleModerator(circleId)
        && get(/databases/$(database)/documents/circles/$(circleId)).data.creatorId == request.auth.uid;

      // ── Members ──────────────────────────────────────────────────────────
      match /members/{memberId} {
        // Members can read the member list; anyone signed in can read for discovery
        allow read: if isSignedIn();

        // A user can create their own membership doc (join / creator self-add)
        allow create: if isSignedIn() && memberId == request.auth.uid;

        // Moderators can approve/update; the member themselves can update their own doc
        allow update: if isCircleModerator(circleId) || isUser(memberId);

        // Moderators or the member themselves can remove
        allow delete: if isCircleModerator(circleId) || isUser(memberId);
      }

      // ── Messages ─────────────────────────────────────────────────────────
      match /messages/{messageId} {
        allow read: if canAccessCircleContent(circleId);
        allow create: if isCircleMember(circleId)
          && request.resource.data.senderId == request.auth.uid;
        // Sender edits their own message; ANY member may toggle reactions —
        // but a reactions-only update may touch nothing except `reactions`.
        // (Rules can't cheaply validate which uid changed inside the map;
        // accepted residual risk — a member could alter others' reactions.)
        allow update: if isCircleMember(circleId)
          && (
            (resource.data.senderId == request.auth.uid
              && request.resource.data.senderId == resource.data.senderId)
            || request.resource.data.diff(resource.data)
                 .affectedKeys().hasOnly(['reactions'])
          );
        allow delete: if isCircleMember(circleId)
          && (resource.data.senderId == request.auth.uid || isCircleModerator(circleId));
      }

      // ── Activity feed ─────────────────────────────────────────────────────
      match /activityFeed/{itemId} {
        allow read: if canAccessCircleContent(circleId);
        // Only members may post, and only as themselves.
        allow create: if isCircleMember(circleId)
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if false;
      }

      // ── Weekly commitments ────────────────────────────────────────────────
      // Docs carry userId + weekKey (see WeeklyCommitment.toMap). Only the
      // owner may create/update/delete their commitments (the client's
      // setCommitments/markProgress only ever touch the caller's own docs).
      // Reads stay circle-wide.
      match /weeklyCommitments/{commitmentId} {
        allow read: if canAccessCircleContent(circleId);
        allow create: if isCircleMember(circleId)
          && request.resource.data.userId == request.auth.uid;
        allow update: if isCircleMember(circleId)
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == resource.data.userId;
        allow delete: if isCircleMember(circleId)
          && resource.data.userId == request.auth.uid;
      }

      // ── Challenges ────────────────────────────────────────────────────────
      match /challenges/{challengeId} {
        allow read: if canAccessCircleContent(circleId);
        allow create: if isCircleMember(circleId)
          && request.resource.data.creatorId == request.auth.uid;
        // Creator/moderator may edit challenge metadata. Regular members may
        // only touch the collaborative fields the app writes on their behalf:
        // progress tallies (updateProgress) and the vote-driven status flip
        // (vote). creatorId is immutable on every branch.
        allow update: if isCircleMember(circleId)
          && request.resource.data.creatorId == resource.data.creatorId
          && (
            resource.data.creatorId == request.auth.uid
            || isCircleModerator(circleId)
            || request.resource.data.diff(resource.data).affectedKeys()
                 .hasOnly(['memberProgress', 'teamTotal', 'status', 'updatedAtMs'])
          );
        allow delete: if isCircleModerator(circleId);

        match /votes/{userId} {
          allow read: if isCircleMember(circleId);
          allow write: if isUser(userId) && isCircleMember(circleId);
        }
      }

      // ── AI Pulse ──────────────────────────────────────────────────────────
      // Pulses are generated client-side by ANY member's device
      // (CircleAiPulseService via the ai_pulse_banner) — moderator-only
      // writes silently broke the banner for non-moderators.
      match /aiPulse/{pulseId} {
        allow read: if isCircleMember(circleId);
        allow write: if isCircleMember(circleId);
      }

      // ── Removal votes ─────────────────────────────────────────────────────
      match /removalVotes/{voteId} {
        allow read, write: if isCircleModerator(circleId);
      }
    }
  }
}
