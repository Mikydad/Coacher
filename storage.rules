rules_version = '2';

// Deploy with: firebase deploy --only storage
//
// NOTE: isCircleMember() below reads Firestore from Storage rules
// (cross-service rules). That only works when the project's Storage
// service agent has the "Firebase Rules Firestore Service Agent" role —
// the CLI provisions it automatically when a ruleset is *uploaded*.
// Symptom when missing: uploads fail [firebase_storage/unauthorized]
// even though the same membership check passes in firestore.rules.
service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null;
    }

    function isCircleMember(circleId) {
      return isSignedIn() &&
        firestore.exists(
          /databases/(default)/documents/circles/$(circleId)/members/$(request.auth.uid)
        );
    }

    function isValidImageUpload() {
      return request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // Circle chat proof images — uid-prefixed (spoof/overwrite-proof) and
    // create-only (immutable once written). Pre-existing objects with
    // unprefixed names stay readable; only NEW uploads need the prefix.
    match /circles/{circleId}/proofs/{fileName} {
      allow read: if isCircleMember(circleId);
      allow create: if isCircleMember(circleId)
        && isValidImageUpload()
        && fileName.matches(request.auth.uid + '_.*');
    }

    // Challenge progress proof images — scoped to the circle; only members
    // can read, and writes must be uid-prefixed so uploads can't be spoofed
    // or clobbered by other users.
    match /circles/{circleId}/challenge_proofs/{challengeId}/{fileName} {
      allow read: if isCircleMember(circleId);
      allow write: if isCircleMember(circleId)
        && isValidImageUpload()
        && fileName.matches(request.auth.uid + '_.*');
    }

    // Stake photos (accountability PRD P-3, security-critical).
    // Upload happens BEFORE the challenge doc exists (client uploads, then
    // calls stakeCreateChallenge which validates the path), so create is
    // gated on the uid-named filename, not the doc. Reads: the owner
    // always; circle members ONLY while the server has flipped the
    // challenge to photoState == 'revealed'. Deletion is server-side
    // (Admin SDK bypasses rules) — clients can never delete or overwrite.
    match /stake_photos/{challengeId}/{fileName} {
      function stakeDoc() {
        return firestore.get(
          /databases/(default)/documents/stake_challenges/$(challengeId)
        ).data;
      }
      allow create: if isSignedIn()
        && fileName == (request.auth.uid + '.jpg')
        && isValidImageUpload();
      allow read: if isSignedIn() && (
        fileName == (request.auth.uid + '.jpg')
        || (stakeDoc().photoState == 'revealed'
            && isCircleMember(stakeDoc().circleId))
      );
      allow update, delete: if false;
    }

    // Stake evidence photos (M-5) — in-app camera captures. uid-scoped
    // folder, create-only, immutable; readable by the participant and, for
    // dispute review, the challenge's circle.
    match /stake_evidence/{challengeId}/{uid}/{fileName} {
      function evidenceStakeDoc() {
        return firestore.get(
          /databases/(default)/documents/stake_challenges/$(challengeId)
        ).data;
      }
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && isValidImageUpload();
      allow read: if isSignedIn() && (
        request.auth.uid == uid
        || isCircleMember(evidenceStakeDoc().circleId)
      );
      allow update, delete: if false;
    }

    // Feedback screenshots — uid-scoped, create-only, images only, 5MB cap.
    // Tester captures are PNG; gallery attachments from the feedback form
    // are JPEG/HEIC. No client read: reports are reviewed in the Firebase
    // console. Path is written by FeedbackScreenshotStorage.
    match /feedback/{uid}/{fileName} {
      allow read: if false;
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && fileName.matches(request.auth.uid + '_.*')
        && request.resource.contentType.matches('image/.*')
        && request.resource.size < 5 * 1024 * 1024;
      allow update, delete: if false;
    }
  }
}
